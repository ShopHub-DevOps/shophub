# Copy this file to .env and adjust values for your local environment.
# The .env file is git-ignored - never commit real credentials.

# --- PostgreSQL (ShopHub platform database) ---
POSTGRES_USER=shophub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=shophub
# Host-side port for the postgres service (container side is always 5432).
POSTGRES_PORT=5432

# --- Backend ---
# Host-side port for the backend service (container side is always 3000).
BACKEND_PORT=8080

# --- Auth ---
# Secret used to sign JWTs. Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-character-random-string
# JWT lifetime. Accepts ms-style ('15m', '24h', '7d') or seconds as a number.
JWT_EXPIRES_IN=24h

# --- SIWE (Sign-In With Ethereum) ---
# Domain the user is signing in to. Must match the frontend host.
SIWE_DOMAIN=localhost:3000
# Full origin (scheme + host + port) the frontend is served from.
SIWE_ORIGIN=http://localhost:3000

# --- Frontend ---
# Host-side port for the frontend service (container side is always 3000).
FRONTEND_PORT=3000
